NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Never expose a Supabase service role key in this Next.js app.
# Service role keys bypass RLS and must not be added as NEXT_PUBLIC_* variables.

# Disabled by default for RC1. Enable only during controlled diagnostics.
NEXT_PUBLIC_ENABLE_ERROR_LOGGING=false
NEXT_PUBLIC_ENABLE_PERFORMANCE_MONITORING=false
